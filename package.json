{
  "name": "wepl-report-viewer",
  "version": "1.0.0",
  "description": "Desktop WEPL report viewer with modular data sources",
  "main": "dist/electron/main.js",
  "author": "WEPL",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node scripts/run-electron.js",
    "dev": "tsc --watch & electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.wepl.report-viewer",
    "productName": "WEPL Report Viewer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "WEPL-Report-Viewer-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "ShayT0u",
      "repo": "wepl-report-viewer"
    }
  }
}
